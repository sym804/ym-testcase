# ── Backend ──

# JWT 서명 키 (필수: production에서 반드시 설정)
SECRET_KEY=your-secret-key-here

# 환경 (development | production)
ENV=development

# 데이터베이스 URL (기본: SQLite)
DATABASE_URL=sqlite:///./tc_manager.db

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT 토큰 만료 시간 (시간 단위, 기본: 2)
TOKEN_EXPIRE_HOURS=2

# ── Test ──

# 테스트 서버 URL
TEST_BASE_URL=http://localhost:8008

# 테스트용 admin 비밀번호
TEST_ADMIN_PASSWORD=test1234

# ── Frontend (Vite) ──

# API 서버 URL (빈 문자열이면 같은 호스트 사용)
VITE_API_URL=
