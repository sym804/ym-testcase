# ============================================================
# YM TestCase - 환경변수 설정
# 이 파일을 .env로 복사한 뒤 값을 수정하세요:
#   cp .env.example .env
# ============================================================

# ── 필수 설정 ──────────────────────────────────────────────

# JWT 서명 키 — 로그인 토큰 암호화에 사용
# 반드시 아래 값을 지우고 본인만의 랜덤 문자열로 교체하세요
# 예시: openssl rand -hex 32  또는 아무 긴 문자열
# 미설정 시 서버 재시작할 때마다 로그인이 풀립니다
SECRET_KEY=change-me-to-a-random-string

# ── 선택 설정 (기본값으로 동작, 필요할 때만 수정) ──────────

# 환경 모드: development 또는 production
# production으로 설정하면 SECRET_KEY 미설정 시 서버가 시작되지 않습니다
ENV=development

# 데이터베이스 URL (기본: 프로젝트 폴더에 SQLite 파일 생성)
# 예시: sqlite:///./tc_manager.db  (기본값)
# 예시: postgresql://user:pass@localhost:5432/tcdb  (PostgreSQL 사용 시)
DATABASE_URL=sqlite:///./tc_manager.db

# CORS 허용 오리진 (프론트엔드 주소, 쉼표로 여러 개 가능)
# 기본값 그대로면 로컬 개발에서 잘 동작합니다
# 예시: https://my-domain.com  (외부 배포 시 변경)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT 토큰 만료 시간 (시간 단위, 기본: 72시간 = 3일)
# 예시: 8  (8시간 유지하고 싶을 때)
TOKEN_EXPIRE_HOURS=72
